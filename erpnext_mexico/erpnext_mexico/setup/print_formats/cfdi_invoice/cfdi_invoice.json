[
  {
    "doctype": "Print Format",
    "name": "CFDI Invoice MX",
    "module": "CFDI",
    "doc_type": "Sales Invoice",
    "standard": "Yes",
    "print_format_type": "Jinja",
    "raw_printing": 0,
    "custom_format": 1,
    "html": "<div class=\"cfdi-print\">\n    <style>\n        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Source+Sans+3:wght@400;500;600&display=swap');\n\n        .cfdi-print {\n            font-family: 'Source Sans 3', 'Helvetica Neue', Arial, sans-serif;\n            color: #1A1D26;\n            max-width: 800px;\n            margin: 0 auto;\n            font-size: 13px;\n            line-height: 1.5;\n        }\n\n        /* ── Header ─────────────────────────────── */\n        .cfdi-header {\n            display: flex;\n            justify-content: space-between;\n            align-items: flex-start;\n            padding-bottom: 16px;\n            border-bottom: 2px solid #0052CC;\n            margin-bottom: 16px;\n        }\n        .cfdi-header__company { flex: 1; }\n        .cfdi-header__company img { max-height: 52px; margin-bottom: 8px; display: block; }\n        .cfdi-header__company h2 {\n            font-family: 'DM Sans', sans-serif;\n            font-size: 18px;\n            font-weight: 700;\n            margin: 0 0 4px;\n            color: #1A1D26;\n        }\n        .cfdi-header__fiscal { font-size: 12px; color: #6B7280; line-height: 1.6; }\n\n        .cfdi-header__cfdi { text-align: right; min-width: 180px; }\n        .cfdi-tipo {\n            background: #0052CC;\n            color: #fff;\n            padding: 4px 12px;\n            border-radius: 4px;\n            font-weight: 700;\n            font-size: 12px;\n            display: inline-block;\n            margin-bottom: 8px;\n            letter-spacing: 0.3px;\n        }\n        .cfdi-folio {\n            font-family: 'DM Sans', sans-serif;\n            font-size: 20px;\n            font-weight: 700;\n            color: #1A1D26;\n        }\n        .cfdi-fecha { font-size: 11px; color: #6B7280; margin-top: 2px; }\n        .cfdi-pago-meta { margin-top: 6px; font-size: 11px; color: #374151; }\n\n        /* ── Receptor ────────────────────────────── */\n        .cfdi-receptor {\n            background: #F8F9FB;\n            border-radius: 8px;\n            padding: 14px 16px;\n            margin-bottom: 16px;\n        }\n        .cfdi-receptor h3 {\n            font-family: 'DM Sans', sans-serif;\n            font-size: 13px;\n            font-weight: 700;\n            margin: 0 0 8px;\n            color: #0052CC;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n        .cfdi-receptor__grid {\n            display: grid;\n            grid-template-columns: 120px 1fr 120px 1fr;\n            gap: 4px 16px;\n            font-size: 12px;\n        }\n        .cfdi-receptor__label { color: #6B7280; }\n        .cfdi-receptor__value { font-weight: 500; color: #1A1D26; }\n\n        /* ── Items table ─────────────────────────── */\n        .cfdi-items {\n            width: 100%;\n            border-collapse: collapse;\n            margin-bottom: 16px;\n            font-size: 12px;\n        }\n        .cfdi-items th {\n            background: #1A1D26;\n            color: #fff;\n            padding: 8px 10px;\n            text-align: left;\n            font-weight: 600;\n            font-size: 11px;\n            text-transform: uppercase;\n            letter-spacing: 0.4px;\n        }\n        .cfdi-items th.text-right,\n        .cfdi-items td.text-right { text-align: right; }\n        .cfdi-items tbody tr:nth-child(even) { background: #F8F9FB; }\n        .cfdi-items td {\n            padding: 7px 10px;\n            border-bottom: 1px solid #E5E7EB;\n            color: #1A1D26;\n            vertical-align: top;\n        }\n        .sat-key {\n            font-family: 'SFMono-Regular', Consolas, monospace;\n            font-size: 11px;\n            color: #0052CC;\n        }\n        .item-desc { color: #374151; }\n        .item-desc small { display: block; color: #9CA3AF; font-size: 10px; margin-top: 1px; }\n\n        /* ── Totals ──────────────────────────────── */\n        .cfdi-totals { display: flex; justify-content: flex-end; margin-bottom: 20px; }\n        .cfdi-totals__table { width: 300px; font-size: 13px; border-collapse: collapse; }\n        .cfdi-totals__table td { padding: 4px 0; }\n        .cfdi-totals__table td:last-child { text-align: right; }\n        .cfdi-totals__table .subtotal-row td { color: #6B7280; }\n        .cfdi-totals__table .tax-row td { color: #374151; }\n        .cfdi-totals__table .total-row td {\n            font-family: 'DM Sans', sans-serif;\n            font-weight: 700;\n            font-size: 16px;\n            border-top: 2px solid #1A1D26;\n            padding-top: 8px;\n            color: #1A1D26;\n        }\n        .cfdi-amount-words {\n            font-size: 11px;\n            color: #6B7280;\n            font-style: italic;\n            text-align: right;\n            margin-top: 4px;\n        }\n\n        /* ── Stamp / Timbre ──────────────────────── */\n        .cfdi-stamp {\n            background: #F1F3F9;\n            border-radius: 8px;\n            padding: 16px;\n            margin-top: 16px;\n            font-size: 10px;\n        }\n        .cfdi-stamp h3 {\n            font-family: 'DM Sans', sans-serif;\n            font-size: 12px;\n            font-weight: 700;\n            margin: 0 0 10px;\n            color: #0052CC;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n        .cfdi-stamp__uuid {\n            font-family: 'SFMono-Regular', Consolas, monospace;\n            font-size: 13px;\n            font-weight: 700;\n            color: #1A1D26;\n            letter-spacing: 0.3px;\n            margin-bottom: 10px;\n            word-break: break-all;\n        }\n        .cfdi-stamp__body { display: flex; gap: 16px; align-items: flex-start; }\n        .cfdi-stamp__fields { flex: 1; }\n        .cfdi-stamp__field { margin-bottom: 5px; }\n        .cfdi-stamp__label { color: #6B7280; font-weight: 600; display: inline-block; min-width: 110px; }\n        .cfdi-stamp__value {\n            word-break: break-all;\n            font-family: 'SFMono-Regular', Consolas, monospace;\n            color: #374151;\n        }\n        .cfdi-stamp__qr { text-align: center; flex-shrink: 0; }\n        .cfdi-stamp__qr img { width: 110px; height: 110px; display: block; }\n        .cfdi-stamp__qr small { display: block; font-size: 9px; color: #9CA3AF; margin-top: 3px; }\n\n        /* ── Footer ──────────────────────────────── */\n        .cfdi-footer {\n            margin-top: 16px;\n            padding-top: 12px;\n            border-top: 1px solid #E5E7EB;\n            font-size: 10px;\n            color: #9CA3AF;\n            text-align: center;\n            line-height: 1.6;\n        }\n        .cfdi-footer strong { color: #6B7280; }\n    </style>\n\n    {%- set company_doc = frappe.get_cached_doc(\"Company\", doc.company) -%}\n    {%- set customer_doc = frappe.get_cached_doc(\"Customer\", doc.customer) if doc.customer else None -%}\n\n    {%- set mx_rfc_emisor = company_doc.get(\"mx_rfc\") or \"\" -%}\n    {%- set mx_regimen_emisor = company_doc.get(\"mx_regimen_fiscal\") or \"\" -%}\n    {%- set mx_cp_emisor = company_doc.get(\"mx_lugar_expedicion\") or \"\" -%}\n    {%- set mx_nombre_fiscal = company_doc.get(\"mx_nombre_fiscal\") or doc.company -%}\n    {%- set company_logo = company_doc.get(\"company_logo\") or \"\" -%}\n\n    {%- set mx_rfc_receptor = \"\" -%}\n    {%- set mx_regimen_receptor = \"\" -%}\n    {%- set mx_cp_receptor = \"\" -%}\n    {%- if customer_doc -%}\n        {%- set mx_rfc_receptor = customer_doc.get(\"mx_rfc\") or \"\" -%}\n        {%- set mx_regimen_receptor = customer_doc.get(\"mx_regimen_fiscal\") or \"\" -%}\n        {%- set mx_cp_receptor = customer_doc.get(\"mx_domicilio_fiscal_cp\") or \"\" -%}\n    {%- endif -%}\n\n    <!-- ── HEADER ──────────────────────────────────── -->\n    <div class=\"cfdi-header\">\n        <div class=\"cfdi-header__company\">\n            {% if company_logo %}\n            <img src=\"{{ company_logo }}\" alt=\"Logo\">\n            {% endif %}\n            <h2>{{ mx_nombre_fiscal }}</h2>\n            <div class=\"cfdi-header__fiscal\">\n                <strong>RFC:</strong> {{ mx_rfc_emisor }}<br>\n                {% if mx_regimen_emisor %}<strong>Régimen:</strong> {{ mx_regimen_emisor }}<br>{% endif %}\n                {% if mx_cp_emisor %}<strong>Lugar de expedición (CP):</strong> {{ mx_cp_emisor }}{% endif %}\n            </div>\n        </div>\n        <div class=\"cfdi-header__cfdi\">\n            <span class=\"cfdi-tipo\">CFDI 4.0 — Factura</span><br>\n            <div class=\"cfdi-folio\">\n                {% if doc.mx_serie %}{{ doc.mx_serie }}&nbsp;{% endif %}{{ doc.name }}\n            </div>\n            <div class=\"cfdi-fecha\">{{ doc.posting_date }}</div>\n            {% if doc.mx_metodo_pago or doc.mx_forma_pago %}\n            <div class=\"cfdi-pago-meta\">\n                {% if doc.mx_metodo_pago %}<strong>Método:</strong> {{ doc.mx_metodo_pago }}{% endif %}\n                {% if doc.mx_forma_pago %} &nbsp;|&nbsp; <strong>Forma:</strong> {{ doc.mx_forma_pago }}{% endif %}\n            </div>\n            {% endif %}\n        </div>\n    </div>\n\n    <!-- ── RECEPTOR ────────────────────────────────── -->\n    <div class=\"cfdi-receptor\">\n        <h3>Receptor</h3>\n        <div class=\"cfdi-receptor__grid\">\n            <span class=\"cfdi-receptor__label\">Cliente</span>\n            <span class=\"cfdi-receptor__value\">{{ doc.customer_name }}</span>\n            <span class=\"cfdi-receptor__label\">RFC</span>\n            <span class=\"cfdi-receptor__value\">{{ mx_rfc_receptor or \"—\" }}</span>\n\n            <span class=\"cfdi-receptor__label\">Régimen fiscal</span>\n            <span class=\"cfdi-receptor__value\">{{ mx_regimen_receptor or \"—\" }}</span>\n            <span class=\"cfdi-receptor__label\">Domicilio fiscal (CP)</span>\n            <span class=\"cfdi-receptor__value\">{{ mx_cp_receptor or \"—\" }}</span>\n\n            <span class=\"cfdi-receptor__label\">Uso CFDI</span>\n            <span class=\"cfdi-receptor__value\">{{ doc.mx_uso_cfdi or \"—\" }}</span>\n            <span class=\"cfdi-receptor__label\">Moneda</span>\n            <span class=\"cfdi-receptor__value\">{{ doc.currency or \"MXN\" }}</span>\n        </div>\n    </div>\n\n    <!-- ── CONCEPTOS ───────────────────────────────── -->\n    <table class=\"cfdi-items\">\n        <thead>\n            <tr>\n                <th style=\"width:90px;\">Clave SAT</th>\n                <th>Descripción</th>\n                <th style=\"width:70px;\">Clave Unidad</th>\n                <th class=\"text-right\" style=\"width:60px;\">Cant.</th>\n                <th class=\"text-right\" style=\"width:90px;\">P. Unitario</th>\n                <th class=\"text-right\" style=\"width:100px;\">Importe</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.items %}\n            <tr>\n                <td class=\"sat-key\">{{ item.get(\"mx_clave_prod_serv\") or \"—\" }}</td>\n                <td class=\"item-desc\">\n                    {{ item.item_name or item.description }}\n                    {% if item.get(\"mx_no_identificacion\") %}\n                    <small>No. ID: {{ item.mx_no_identificacion }}</small>\n                    {% endif %}\n                </td>\n                <td class=\"sat-key\">{{ item.get(\"mx_clave_unidad\") or item.uom }}</td>\n                <td class=\"text-right\">{{ item.qty | float | round(2) }}</td>\n                <td class=\"text-right\">{{ frappe.format(item.rate, {\"fieldtype\": \"Currency\", \"currency\": doc.currency}) }}</td>\n                <td class=\"text-right\">{{ frappe.format(item.amount, {\"fieldtype\": \"Currency\", \"currency\": doc.currency}) }}</td>\n            </tr>\n            {% endfor %}\n        </tbody>\n    </table>\n\n    <!-- ── TOTALES ─────────────────────────────────── -->\n    <div class=\"cfdi-totals\">\n        <div>\n            <table class=\"cfdi-totals__table\">\n                <tr class=\"subtotal-row\">\n                    <td>Subtotal</td>\n                    <td>{{ frappe.format(doc.net_total, {\"fieldtype\": \"Currency\", \"currency\": doc.currency}) }}</td>\n                </tr>\n                {% for tax in doc.taxes %}\n                <tr class=\"tax-row\">\n                    <td>{{ tax.description }}</td>\n                    <td>{{ frappe.format(tax.tax_amount, {\"fieldtype\": \"Currency\", \"currency\": doc.currency}) }}</td>\n                </tr>\n                {% endfor %}\n                {% if doc.discount_amount and doc.discount_amount > 0 %}\n                <tr class=\"tax-row\">\n                    <td>Descuento</td>\n                    <td>-{{ frappe.format(doc.discount_amount, {\"fieldtype\": \"Currency\", \"currency\": doc.currency}) }}</td>\n                </tr>\n                {% endif %}\n                <tr class=\"total-row\">\n                    <td>Total</td>\n                    <td>{{ frappe.format(doc.grand_total, {\"fieldtype\": \"Currency\", \"currency\": doc.currency}) }}&nbsp;{{ doc.currency }}</td>\n                </tr>\n            </table>\n            <div class=\"cfdi-amount-words\">\n                {{ amount_to_words_mx(doc.grand_total, doc.currency) }}\n            </div>\n        </div>\n    </div>\n\n    <!-- ── TIMBRE FISCAL DIGITAL ───────────────────── -->\n    {% if doc.get(\"mx_cfdi_uuid\") %}\n    <div class=\"cfdi-stamp\">\n        <h3>Timbre Fiscal Digital — SAT</h3>\n        <div class=\"cfdi-stamp__uuid\">{{ doc.mx_cfdi_uuid }}</div>\n        <div class=\"cfdi-stamp__body\">\n            <div class=\"cfdi-stamp__fields\">\n                <div class=\"cfdi-stamp__field\">\n                    <span class=\"cfdi-stamp__label\">Fecha timbrado:</span>\n                    <span>{{ doc.get(\"mx_cfdi_fecha_timbrado\") or doc.mx_cfdi_status or \"—\" }}</span>\n                </div>\n                <div class=\"cfdi-stamp__field\">\n                    <span class=\"cfdi-stamp__label\">No. Cert. SAT:</span>\n                    <span class=\"cfdi-stamp__value\">{{ doc.get(\"mx_no_certificado_sat\") or \"—\" }}</span>\n                </div>\n                <div class=\"cfdi-stamp__field\">\n                    <span class=\"cfdi-stamp__label\">No. Cert. Emisor:</span>\n                    <span class=\"cfdi-stamp__value\">{{ doc.get(\"mx_no_certificado\") or \"—\" }}</span>\n                </div>\n                {% if doc.get(\"mx_sello_cfdi\") %}\n                <div class=\"cfdi-stamp__field\" style=\"margin-top:6px;\">\n                    <span class=\"cfdi-stamp__label\">Sello CFDI:</span><br>\n                    <span class=\"cfdi-stamp__value\" style=\"font-size:9px;\">{{ doc.mx_sello_cfdi[:80] }}...</span>\n                </div>\n                {% endif %}\n                {% if doc.get(\"mx_sello_sat\") %}\n                <div class=\"cfdi-stamp__field\" style=\"margin-top:4px;\">\n                    <span class=\"cfdi-stamp__label\">Sello SAT:</span><br>\n                    <span class=\"cfdi-stamp__value\" style=\"font-size:9px;\">{{ doc.mx_sello_sat[:80] }}...</span>\n                </div>\n                {% endif %}\n                {% if doc.get(\"mx_cadena_original_tfd\") %}\n                <div class=\"cfdi-stamp__field\" style=\"margin-top:6px;\">\n                    <span class=\"cfdi-stamp__label\">Cadena original TFD:</span><br>\n                    <span class=\"cfdi-stamp__value\" style=\"font-size:9px; word-break:break-all;\">{{ doc.mx_cadena_original_tfd[:120] }}...</span>\n                </div>\n                {% endif %}\n            </div>\n            <div class=\"cfdi-stamp__qr\">\n                <img\n                    src=\"https://api.qrserver.com/v1/create-qr-code/?size=200x200&data={{ 'https://verificacfdi.facturaelectronica.sat.gob.mx/default.aspx?id=' ~ doc.mx_cfdi_uuid ~ '&re=' ~ mx_rfc_emisor ~ '&rr=' ~ mx_rfc_receptor ~ '&tt=' ~ (doc.grand_total | string) ~ '&fe=' ~ (doc.get('mx_sello_cfdi') or '')[-8:] | urlencode }}\"\n                    alt=\"QR Verificación SAT\"\n                >\n                <small>Verificar en SAT</small>\n            </div>\n        </div>\n    </div>\n    {% else %}\n    <div class=\"cfdi-stamp\" style=\"border: 2px dashed #E5E7EB; background: #FAFAFA;\">\n        <h3 style=\"color: #9CA3AF;\">Sin Timbre Fiscal Digital</h3>\n        <p style=\"color: #9CA3AF; font-size: 11px; margin: 0;\">Este documento aún no ha sido timbrado por el SAT.</p>\n    </div>\n    {% endif %}\n\n    <!-- ── FOOTER ──────────────────────────────────── -->\n    <div class=\"cfdi-footer\">\n        <strong>Este documento es la representación impresa de un Comprobante Fiscal Digital por Internet (CFDI).</strong><br>\n        Verifique la autenticidad en:\n        <strong>https://verificacfdi.facturaelectronica.sat.gob.mx</strong><br>\n        Generado con ERPNext México — MD Consultoría SC\n    </div>\n</div>\n"
  }
]